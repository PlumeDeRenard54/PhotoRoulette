@startuml
package Modele {
    class User {
     name : String
     score : int
     serverurUtilisateur : Server
     creerContenue() : Contenu
    }

    abstract class Manche {
        centenu : Contenu
        pointMax : int
        tickDepart : long
        calculerPoint(tick long)
        start() : Map<User,Int>
    }

    interface Contenu {
        proprietaire : User
        lecture()
    }

    class ContenuImage {
        image : Image
    }

    class ContenuVideo {
        video : Video
    }

    abstract class Partie {
        joueurs : List<User>
        ListeManches : List<Manche>
        ajouterJoueur(j :User)
        supprimerJoueur(j :User))
        creerManches()
        start() : List<User,int>
    }
}

package communication{
    package serveur {
        class Client {
        - Socket socket
        - PrintWriter out
        - BufferedReader in
        - Thread listener
        + void send(Message)
        }


        class Server {
        - {static} Server singleton
        - ServerSocket serverSocket
        - Thread clientSearch
        + Server getServer()
        }
        Server "1" ..> "*" Client : socketList
}
class Message {
+ String type
+ String contenu
+ JSONObject getJson()
+ {static} Message fromJson(String)
    }

    package client {
        class Client
    }
}

ContenuImage ..|> Contenu
ContenuVideo ..|> Contenu
Manche --> Contenu
Partie --> User
Partie --> Manche
@enduml